# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# ── Environment Variables ──────────────────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Audio Upload Temp Files ────────────────────────────────────────────────────
# Both services store audio temporarily — never commit these
server/uploads/*
!server/uploads/.gitkeep
audio-service/uploads/*
!audio-service/uploads/.gitkeep

# ── Large Binary / ML Model Files ─────────────────────────────────────────────
# ffmpeg binary (202 MB) — download separately, never commit
*.exe
*.bin
ffmpeg*
ffprobe*

# Whisper & PyTorch model weights
audio-service/models/
*.pt
*.pth
*.onnx
*.pkl
*.safetensors

# ── Stutter-Solver Research Repo ──────────────────────────────────────────────
# This is a 194 MB external ML research repo — not used in production
audio-service/Stutter-Solver/

# ── Test & Debug Artifacts ────────────────────────────────────────────────────
audio-service/dummy.wav
test_stutter_solver.py
verify_setup.py
*.test.wav
*.test.mp3

# ── IDE & Editor Files ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.claude/

# ── OS Junk ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Database (SQLite dev only) ────────────────────────────────────────────────
*.sqlite
*.sqlite3
*.db

# ── Build Artifacts ───────────────────────────────────────────────────────────
dist/
build/
.next/
